# ─────────────────────────────────────────────────────────────────────────────
# AlphaLens PE — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to source control
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Local Docker (default)
DB_PASSWORD=alphalens_secret

# AWS RDS / Supabase / Neon / Railway example:
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/alphalens

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_in_production_generate_32_chars

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Production example:
# CORS_ORIGINS=https://alphalens-pe.netlify.app,https://api.yourdomain.com

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL of the backend API (used at build time by Vite)
VITE_API_URL=http://localhost:8000

# Production example:
# VITE_API_URL=https://api.yourdomain.com
